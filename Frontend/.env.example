# Frontend env vars for Vite

# --- Legacy Google Play (cordova-plugin-purchase) – kept for reference ---
# Set to your exact Google Play subscription product ID (as created in Play Console)
VITE_GOOGLE_PLAY_PRODUCT_ID=havenn_premium_monthly

# --- RevenueCat (Android / Cordova only) ---
# Production key starts with "goog_". For sandbox testing use the Test Store key
# (starts with "test_"). This is a PUBLIC SDK key, safe to ship in the Android app.
# Put the real value in .env (NOT here – this file is committed to git).
VITE_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxx

# Entitlement IDENTIFIER from RevenueCat → Entitlements tab (short slug in the
# "Identifier" column, not the display name). Defaults to "premium".
VITE_REVENUECAT_ENTITLEMENT_ID=premium

# Optional: force a specific Offering identifier. Leave empty to use the "current" offering.
VITE_REVENUECAT_OFFERING_ID=
