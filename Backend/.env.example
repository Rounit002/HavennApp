# Database Configuration
DB_USER=your_db_user
DB_HOST=localhost
DB_NAME=library_management
DB_PASSWORD=your_db_password
DB_PORT=5432

# Email Configuration (Brevo/Sendinblue)
BREVO_API_KEY=your_brevo_api_key
BREVO_TEMPLATE_ID=your_template_id

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server Configuration
PORT=3000
SESSION_SECRET=your_session_secret_here

# Google Play Billing (Server)
# Provide either inline JSON or a file path to the service account key
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/...gserviceaccount.com"}
# GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json
GOOGLE_PLAY_PACKAGE_NAME=com.havenn.studyspace
GOOGLE_PLAY_PRODUCT_ID=havenn_premium_monthly
# Optional shared secret for webhook authentication (Pub/Sub push)
GOOGLE_PLAY_WEBHOOK_TOKEN=<replace-with-a-strong-random-token>

# RevenueCat (Server)
# Secret API key (v1) from RevenueCat dashboard → Project → API keys (starts with "sk_").
# Used for server-to-server REST calls (subscriber lookup) and MUST stay private.
REVENUECAT_SECRET_API_KEY=goog_cHbeKVNeILdQPzQHAasSOFcCCcN
# Entitlement identifier configured in RevenueCat (must match VITE_REVENUECAT_ENTITLEMENT_ID).
REVENUECAT_ENTITLEMENT_ID=Havenn Library Pro
# Shared secret expected in the Authorization header of incoming RevenueCat webhooks.
# Set the same value in RevenueCat dashboard → Integrations → Webhooks → Authorization header.
REVENUECAT_WEBHOOK_AUTH_HEADER=<replace-with-a-strong-random-token>
