{
  "name": "com.havenn.studyspace",
  "displayName": "Havenn",
  "version": "1.0.0",
  "description": "Havenn — Study space management (Cordova)",
  "main": "index.js",
  "scripts": {
    "prepare": "cordova prepare",
    "build:web": "cd ../Frontend && npm run build",
    "sync:www": "rimraf www && cpr ../Frontend/dist www",
    "build:android": "npm run build:web && npm run sync:www && cordova build android",
    "build:android:release": "npm run build:web && npm run sync:www && cordova build android --release"
  },
  "keywords": [
    "cordova",
    "havenn",
    "studyspace"
  ],
  "author": "Lumenbyte Softwares",
  "license": "Apache-2.0",
  "cordova": {
    "platforms": [
      "android"
    ],
    "plugins": {
      "cordova-plugin-camera": {
        "ANDROIDX_CORE_VERSION": "1.6.+"
      },
      "cordova-plugin-filepath": {},
      "cordova-plugin-android-permissions": {},
      "cordova-plugin-purchases": {}
    }
  },
  "devDependencies": {
    "cordova-android": "^15.0.0",
    "cordova-plugin-android-permissions": "^1.1.5",
    "cordova-plugin-purchases": "^8.0.7",
    "cpr": "^3.0.1",
    "rimraf": "^5.0.0"
  }
}
